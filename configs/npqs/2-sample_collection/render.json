{
  "id": "npqs-draw-sample:render",
  "type": "APPLICATION",
  "title": "[NPQS] Sample Collection",
  "sections": {
    "status_message": {
      "templateId": "npqs-draw-sample--status",
      "title": "Sample Collection Status",
      "projector": "MARKDOWN",
      "visibleWhen": {
        "states": ["PENDING_USER", "QUEUED_EXTERNALLY"]
      }
    },
    "results_summary": {
      "templateId": "npqs-draw-sample--results",
      "title": "Sample Registration Confirmed",
      "projector": "MARKDOWN",
      "dataKey": "officer_receive",
      "visibleWhen": {
        "requireDataKey": "officer_receive"
      }
    },
    "submission_form": {
      "templateId": "npqs-draw-sample--trader-submit-form",
      "title": "Sample Drop-Off Confirmation",
      "projector": "FORM",
      "dataKey": "traderinput",
      "visibleWhen": {
        "states": ["PENDING_USER"]
      },
      "handles": [
        {
          "command": "submit",
          "label": "Confirm Sample Dropped Off",
          "element": "primary_action"
        }
      ]
    }
  },
  "states": {
    "PENDING_USER": {
      "actions": [{ "command": "submit" }]
    }
  }
}
