# IdP Configuration

# Required: Admin user credentials used by the bootstrap container
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234

# Required: Default password for sample users created by bootstrap
SAMPLE_USER_PASSWORD=1234

# Required: Default M2M client secret used by sample M2M apps
M2M_CLIENT_SECRET=1234

# Optional: client secret for the `admin-cli` bootstrap M2M client (client_id
# ADMIN_CLI), used to mint a `system`-scoped management token. Defaults to 1234.
# If you change it, it must match between the thunderid-setup bootstrap (which
# creates the client) and the thunderid-seed service (which uses it).
# ADMIN_CLI_SECRET=1234

# Required: Base URL for API used by idp/sample-resources.sh
# For local development this is typically https://localhost:8090
API_BASE=https://localhost:8090

# Required when running idp/sample-resources.sh by hand against a real deployment
# (management APIs require auth). Leave unset for the localhost security-disabled
# bootstrap (or run with ALLOW_NO_AUTH=1). Treat as a secret — do not commit a real value.
# AUTH_TOKEN=

# Set INSECURE=0 to enforce TLS certificate validation. Default (1) skips it for
# self-signed localhost certs.
# INSECURE=1

# Required: Used by deployment.yaml placeholder
PUBLIC_URL=https://localhost:8090
PORT=8090
HOSTNAME=0.0.0.0

# Required: Additional CORS origins loaded into deployment.yaml
# Keep indices sequential with no gaps (0, 1, 2, ...).
# These are added on top of the localhost fallback origins in deployment.yaml.
CORS_ORIGINS_0=http://localhost:5173
CORS_ORIGINS_1=https://localhost:5173
CORS_ORIGINS_2=http://localhost:5174
CORS_ORIGINS_3=https://localhost:5174
CORS_ORIGINS_4=http://localhost:5175
CORS_ORIGINS_5=https://localhost:5175
CORS_ORIGINS_6=http://localhost:5176
CORS_ORIGINS_7=https://localhost:5176
CORS_ORIGINS_8=http://localhost:5177
CORS_ORIGINS_9=https://localhost:5177
CORS_ORIGINS_10=http://localhost:5178
CORS_ORIGINS_11=https://localhost:5178
CORS_ORIGINS_12=http://localhost:5179
CORS_ORIGINS_13=https://localhost:5179

# Required if email SMTP is configured via deployment.yaml placeholders.
# Thunder startup fails if these are missing when placeholders are present.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=team@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_ENABLE_START_TLS=true
SMTP_ENABLE_AUTHENTICATION=true

# ----------------------
# Advanced / Optional
# Uncomment or add the variables below to override specific sample
# user passwords or M2M client secrets per-application.
#
# These variable NAMES are referenced from the declarative config under
# idp/resources/ (passwordEnv / secretEnv / redirectUrisEnv) — the JSON files
# hold only the names, never the secret values, so set the values here.
# Each falls back to SAMPLE_USER_PASSWORD / M2M_CLIENT_SECRET when unset.

# Per-sample-user overrides
# SAMPLE_NPQS_OFFICER_PASSWORD=...
# SAMPLE_FCAU_OFFICER_PASSWORD=...
# SAMPLE_CDA_OFFICER_PASSWORD=...
# SAMPLE_SLPA_OFFICER_PASSWORD=...
# SAMPLE_CUSTOMS_OFFICER_PASSWORD=...
# SAMPLE_SLTB_OFFICER_PASSWORD=...

# Per-M2M client secrets — outbound (Agency -> NSW)
# M2M_NPQS_TO_NSW_SECRET=...
# M2M_FCAU_TO_NSW_SECRET=...
# M2M_CDA_TO_NSW_SECRET=...
# M2M_SLPA_TO_NSW_SECRET=...
# M2M_CUSTOMS_TO_NSW_SECRET=...
# M2M_SLTB_TO_NSW_SECRET=...

# Per-M2M client secrets — inbound (NSW -> Agency)
# M2M_NSW_TO_NPQS_SECRET=...
# M2M_NSW_TO_FCAU_SECRET=...
# M2M_NSW_TO_CDA_SECRET=...
# M2M_NSW_TO_SLPA_SECRET=...
# M2M_NSW_TO_CUSTOMS_SECRET=...
# M2M_NSW_TO_SLTB_SECRET=...

# Per-SPA OAuth redirect URIs (space- or comma-separated; multiple allowed).
# When unset, each SPA defaults to http(s)://localhost:<port> for local dev.
# Set these for real deployments where the portals are not on localhost.
# TRADER_REDIRECT_URIS="https://trader.example.lk https://trader.example.lk/callback"
# NPQS_REDIRECT_URIS="https://npqs.example.lk"
# FCAU_REDIRECT_URIS="https://fcau.example.lk"
# CDA_REDIRECT_URIS="https://cda.example.lk"
# SLPA_REDIRECT_URIS="https://slpa.example.lk"
# CUSTOMS_REDIRECT_URIS="https://customs.example.lk"
# SLTB_REDIRECT_URIS="https://sltb.example.lk"


