# Copy this file to .env and adjust values for your local environment.
#
# ⚠️  Secrets below (DB_PASSWORD, M2M_NSW_TO_*_SECRET, ARGUS_API_KEY) ship as
# insecure dev placeholders. compose.yml no longer falls back to these values:
# it references them as ${VAR:?...}, so `docker compose up` FAILS FAST (naming
# the variable) if one is unset. Copying this file keeps local dev zero-config;
# set strong, unique values for any UAT/production deployment.

# Database Configuration
DB_HOST=localhost
# Mostly 5432 for local Postgres, let's use a different port to avoid conflicts with any existing local Postgres instances
DB_PORT=55432  
DB_USERNAME=postgres
# Dev placeholder; set a strong value for non-local deployments (see banner above).
DB_PASSWORD=changeme
DB_NAME=nsw_db
# Use 'require' in production to enforce SSL connections to the database
DB_SSLMODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_MAX_CONN_LIFETIME_SECONDS=3600

# Server Configuration
SERVER_PORT=8080
SERVER_DEBUG=true
SERVER_LOG_LEVEL=debug
SERVICE_URL=http://localhost:8080

# Config file paths (relative to the working directory at start-up)
SERVICES_CONFIG_PATH=./configs/services.docker.json
# For local development with direct host DB access, use the non-docker config with localhost references instead of container hostnames.
# SERVICES_CONFIG_PATH=./configs/services.json
PAYMENT_METHODS_CONFIG_PATH=./configs/payment_methods.json

# Artifact Loader Configuration
# Selects where artifacts (workflow definitions, templates, manifest.json) are
# fetched from at startup. Only the settings for the selected type are read.
# Options: 'local', 'github', or 's3'.
ARTIFACT_LOADER_TYPE=local

# Local loader (ARTIFACT_LOADER_TYPE=local): directory that artifact paths are
# resolved against. Must exist at startup.
ARTIFACT_LOCAL_ROOT=configs

# GitHub loader (ARTIFACT_LOADER_TYPE=github): read artifacts from a repo.
# Owner, Repo, and Ref are required; prefer an immutable Ref (tag or SHA).
# ARTIFACT_GITHUB_OWNER=OpenNSW
# ARTIFACT_GITHUB_REPO=nsw-configs
# ARTIFACT_GITHUB_REF=main
# Optional in-repo directory prefix every path resolves against (empty = repo root).
# ARTIFACT_GITHUB_BASE_PATH=
# Required for private repos; lifts the unauthenticated rate limit for public repos.
# ARTIFACT_GITHUB_TOKEN=
# Optional REST API root for GitHub Enterprise Server (default: https://api.github.com).
# ARTIFACT_GITHUB_BASE_URL=
# Fetch from the raw-content host instead of the REST Contents API (no token, no
# REST rate limit; best for public repos pinned to an immutable Ref).
# ARTIFACT_GITHUB_USE_RAW_HOST=false
# Optional raw-content host root when USE_RAW_HOST=true (default: https://raw.githubusercontent.com).
# ARTIFACT_GITHUB_RAW_BASE_URL=

# S3 loader (ARTIFACT_LOADER_TYPE=s3): read artifacts from an S3 bucket.
# Bucket and Region are required.
# ARTIFACT_S3_BUCKET=nsw-configs
# ARTIFACT_S3_REGION=us-east-1
# Optional custom endpoint for S3-compatible stores (MinIO, LocalStack); uses path-style addressing.
# ARTIFACT_S3_ENDPOINT=
# Optional static credentials; must be set together, else the default AWS credential chain is used.
# ARTIFACT_S3_ACCESS_KEY=
# ARTIFACT_S3_SECRET_KEY=
# Optional in-bucket key prefix every path resolves against (empty = bucket root).
# ARTIFACT_S3_PREFIX=

# CORS Configuration
# Here Agency Portals also added. because they are using the storage service directly from the portals
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178,http://localhost:5179
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Storage Configuration
STORAGE_TYPE=local
# Options: 'local' or 's3'
STORAGE_LOCAL_BASE_DIR=./bucket
# Optional local storage tuning
# STORAGE_LOCAL_PUT_SECRET=local-dev-secret
# STORAGE_LOCAL_PUBLIC_URL=http://localhost:8080
# STORAGE_PRESIGN_TTL=15m

# S3 Configuration (only needed when STORAGE_TYPE=s3)
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_BUCKET=nsw-uploads
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_USE_SSL=true
# STORAGE_S3_PUBLIC_URL=

# Authentication Configuration
AUTH_JWKS_URL=https://localhost:8090/oauth2/jwks
AUTH_ISSUER=https://localhost:8090
AUTH_CLIENT_IDS=TRADER_PORTAL_APP,FCAU_TO_NSW,NPQS_TO_NSW,CDA_TO_NSW,SLPA_TO_NSW,CUSTOMS_TO_NSW,SLTB_TO_NSW
AUTH_AUDIENCE=NSW_API
# In local development with self-signed certs, we may need to skip TLS verification for the JWKS endpoint.
AUTH_JWKS_INSECURE_SKIP_VERIFY=true

# Outbound M2M (NSW -> Agency): client secrets used by configs/services*.json to
# obtain client_credentials tokens for calling each agency's POST /api/v1/inject.
# Referenced as env:M2M_NSW_TO_<AGENCY>_SECRET; both the backend config and
# compose.yml (${VAR:?...}) fail loud if unset. Must match the secret registered
# in the IdP for the NSW_TO_<AGENCY> client. Dev placeholder 1234 below; set a
# strong value for non-local deployments.
M2M_NSW_TO_NPQS_SECRET=1234
M2M_NSW_TO_FCAU_SECRET=1234
M2M_NSW_TO_CDA_SECRET=1234
M2M_NSW_TO_SLPA_SECRET=1234
M2M_NSW_TO_CUSTOMS_SECRET=1234
M2M_NSW_TO_SLTB_SECRET=1234

# Outbound (NSW -> Sri Lanka Customs ASYCUDA/CIG declarations API). Referenced
# as env:M2M_NSW_TO_ASYCUDA_SECRET by the "customs-asycuda" service in
# configs/services*.json. Set the real client_credentials secret in your local
# .env (gitignored); this placeholder only needs to be non-empty so startup
# succeeds in dev.
M2M_NSW_TO_ASYCUDA_SECRET=1234

# Temporal Configuration
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# Notification Configuration
# Path to notifications config used by the backend
NOTIFICATIONS_CONFIG_PATH=./configs/notification.json

# TaskAuthz Configuration
# Path to task authz config used by the backend
TASK_AUTHZ_CONFIG_PATH=./configs/task_authz.json

# Trader Portal (Frontend) Configuration
# Host port for the trader portal (Nginx listens on 8080 inside the container).
TRADER_PORTAL_PORT=5173
# These VITE_* values are injected into the SPA at container start and read by
# the browser, so they must point at host-exposed ports (localhost), not the
# internal docker service hostnames.
VITE_API_BASE_URL=http://localhost:8080
VITE_IDP_BASE_URL=https://localhost:8090
VITE_IDP_CLIENT_ID=TRADER_PORTAL_APP
VITE_APP_URL=http://localhost:5173
VITE_IDP_SCOPES=openid,profile,email,group,ou,nsw:consignment:read,nsw:consignment:write,nsw:task:read,nsw:task:write,nsw:hscode:read,nsw:company:read,nsw:cha:read,nsw:storage:read,nsw:storage:write
VITE_IDP_TRADER_GROUP_NAME=Traders
VITE_IDP_CHA_GROUP_NAME=CHA
VITE_SHOW_AUTOFILL_BUTTON=true

# Multi-Repository Local Workspace Configuration (optional)
# Set GOWORK to '/src/go.work' to use local sibling directories instead of GitHub remote dependencies.
# GOWORK=/src/go.work
# CORE_PATH=../core
# CORE_REMOTE_PATH=../core/remote

# Audit Service Configuration (Argus)
ARGUS_PORT=3001
ARGUS_SERVICE_URL=http://localhost:3001
# Shared between the api client and the argus service; both read it via
# compose.yml ${ARGUS_API_KEY:?...} (fails fast if unset). Dev placeholder below;
# set a strong value for non-local deployments.
ARGUS_API_KEY=nsw-super-secret-audit-token

