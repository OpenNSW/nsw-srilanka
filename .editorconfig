root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[*.{js,ts,tsx,json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.md]
# Trailing whitespace is meaningful in Markdown (two spaces = <br>).
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
